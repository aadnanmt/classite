---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css'
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MusicWidget from '../components/MusicWidget.astro';

const { title = 'FOURFO' } = Astro.props;
---

<!doctype html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FOUR FO | {title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body class="bg-gray-900 text-gray-100 font-sans antialiased min-h-screen flex flex-col">

    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50 shadow-lg">
        <Navbar />
    </nav>

    <main class="flex-grow container mx-auto px-4 py-8">
        <slot />
    </main>

    <Footer />
    <MusicWidget />
    
</body>
</html>