---
import '@fontsource-variable/inter'
import '@fontsource-variable/jetbrains-mono'
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

const { title = 'FOURFO' } = Astro.props
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FOUR FO | {title}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
  </head>
  <body class="flex min-h-screen flex-col bg-gray-900 font-sans text-gray-100 antialiased">
    <nav class="sticky top-0 z-50 border-b border-gray-700 bg-gray-800 shadow-lg">
      <Navbar />
    </nav>

    <main class="container mx-auto flex-grow px-4 py-8">
      <slot />
    </main>

    <Footer />
  </body>
</html>
