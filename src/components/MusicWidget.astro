---

<div
  id="persistent-music"
  class="fixed bottom-4 left-1/2 z-50 flex w-[90%] -translate-x-1/2 items-center space-x-3 rounded-lg border border-gray-600 bg-gray-800/90 p-3 shadow-xl backdrop-blur-sm transition-all duration-500 md:right-4 md:left-auto md:w-64 md:translate-x-0"
>
  <audio id="bgm-player" loop>
    <source src="/audio/bgm-navjaxx-test.mp3" type="audio/mpeg" />
  </audio>

  <div class="flex-shrink-0">
    <button
      id="music-toggle-btn"
      class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-white shadow-lg shadow-blue-500/50 hover:bg-blue-500 focus:outline-none"
    >
      <span id="music-icon"><i class="fas fa-play"></i></span>
    </button>
  </div>

  <div class="flex-1 overflow-hidden">
    <p class="text-[10px] tracking-widest text-gray-400 uppercase">Now Playing</p>
    <div class="relative h-5 w-full overflow-hidden">
      <p class="animate-marquee text-sm font-bold whitespace-nowrap text-blue-300">
        Classroom Vibes - FOURFO
      </p>
    </div>
  </div>
</div>

<script>
  // Pindahin logic toggleMusic() lu ke sini biar di-bundle sama Vite
  const btn = document.getElementById('music-toggle-btn')
  const audio = document.getElementById('bgm-player') as HTMLAudioElement
  const icon = document.getElementById('music-icon')

  if (btn && audio && icon) {
    btn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play()
        icon.innerHTML = '<i class="fas fa-pause"></i>'
      } else {
        audio.pause()
        icon.innerHTML = '<i class="fas fa-play"></i>'
      }
    })
  }
</script>
