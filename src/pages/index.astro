---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="Dashboard Kelas">
  <div class="relative py-10 md:py-16">
    <div
      class="absolute top-0 left-1/2 -z-10 h-64 w-3/4 -translate-x-1/2 rounded-full bg-blue-600/20 blur-[100px]"
    >
    </div>

    <div class="mb-16 space-y-4 text-center">
      <div
        class="mb-2 inline-flex items-center gap-3 rounded-lg border border-gray-700 bg-gray-800 px-4 py-1 font-mono text-xs text-green-400"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-lg bg-green-500"></span>
        </span>
        SYSTEM CONNECT
      </div>

      <h1 class="text-5xl font-bold tracking-tight text-white md:text-7xl">
        FOUR<span class="text-blue-500">FO</span>
      </h1>

      <p class="mx-auto max-w-xl border-x border-gray-700/50 font-mono text-lg text-gray-400">
        &lt;Ruang Kelas Teknik Komputer & Jaringan /&gt;
      </p>

      <div class="mt-6 flex justify-center gap-4">
        <a
          href="#modules"
          class="flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-2 font-medium text-white shadow-lg shadow-blue-500/25 transition hover:bg-blue-500"
        >
          <i class="fas fa-terminal"></i> Akses Fitur
        </a>
        <a
          href="https://github.com/aadnanmt/classite"
          target="_blank"
          class="flex items-center gap-2 rounded-lg border border-gray-700 bg-gray-800 px-6 py-2 font-medium text-gray-300 transition hover:bg-gray-700"
        >
          <i class="fab fa-github"></i> Source Code
        </a>
      </div>
    </div>

    <div id="modules" class="mx-auto grid max-w-5xl grid-cols-1 gap-6 px-4 md:grid-cols-3">
      <div
        class="group relative overflow-hidden rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/50"
      >
        <div class="absolute top-0 right-0 p-3 opacity-10 transition group-hover:opacity-20">
          <i class="far fa-calendar-alt text-8xl text-blue-500"></i>
        </div>
        <div class="relative z-10">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg border border-gray-700 bg-gray-800 text-blue-400 transition group-hover:bg-blue-900/20 group-hover:text-blue-300"
          >
            <i class="far fa-calendar-alt text-xl"></i>
          </div>
          <h3 class="mb-2 font-mono text-xl font-bold text-white">Jadwal Pelajaran</h3>
          <p class="mb-4 text-sm text-gray-500">Cek mata pelajaran yang aktif hari ini.</p>
          <span class="rounded border border-gray-700 px-2 py-1 text-xs text-gray-600"
            >SEGERA ADA</span
          >
        </div>
      </div>

      <a
        href="/"
        class="group relative overflow-hidden rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-purple-500/50 hover:shadow-lg hover:shadow-purple-900/20"
      >
        <div class="absolute top-0 right-0 p-3 opacity-10 transition group-hover:opacity-20">
          <i class="fas fa-camera-retro text-8xl text-purple-500"></i>
        </div>
        <div class="relative z-10">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg border border-gray-700 bg-gray-800 text-purple-400 transition group-hover:bg-purple-900/20 group-hover:text-purple-300"
          >
            <i class="fas fa-camera-retro text-xl"></i>
          </div>
          <h3 class="mb-2 font-mono text-xl font-bold text-white">Galeri Kelas</h3>
          <p class="mb-4 text-sm text-gray-500">Dokumentasi & memori kelas.</p>
          <div
            class="flex items-center text-sm font-semibold text-purple-400 transition-transform group-hover:translate-x-2"
          >
            Buka Galeri <i class="fas fa-arrow-right ml-2"></i>
          </div>
        </div>
      </a>

      <a
        href="/"
        class="group relative overflow-hidden rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-green-500/50 hover:shadow-lg hover:shadow-green-900/20"
      >
        <div class="absolute top-0 right-0 p-3 opacity-10 transition group-hover:opacity-20">
          <i class="fas fa-user-secret text-8xl text-green-500"></i>
        </div>
        <div class="relative z-10">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg border border-gray-700 bg-gray-800 text-green-400 transition group-hover:bg-green-900/20 group-hover:text-green-300"
          >
            <i class="fas fa-user-secret text-xl"></i>
          </div>
          <h3 class="mb-2 font-mono text-xl font-bold text-white">Pesan Anonim</h3>
          <p class="mb-4 text-sm text-gray-500">Kirim pesan rahasia.</p>
          <div
            class="flex items-center text-sm font-semibold text-green-400 transition-transform group-hover:translate-x-2"
          >
            Kirim Pesan <i class="fas fa-arrow-right ml-2"></i>
          </div>
        </div>
      </a>
    </div>
  </div>
</MainLayout>
