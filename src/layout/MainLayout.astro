---
// src/layouts/MainLayout.astro
import '../styles/global.css';
const { title = "FOURFO" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
<body class="bg-gray-900 text-gray-100 font-sans antialiased min-h-screen flex flex-col">
    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50 shadow-lg">
        <slot name="navbar" />
    </nav>

    <main class="flex-grow container mx-auto px-4 py-8">
        <slot /> </main>

    <slot name="footer" />

    <script is:inline src="/js/main.js"></script>
</body>
</html>

